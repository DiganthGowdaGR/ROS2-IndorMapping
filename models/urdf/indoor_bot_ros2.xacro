<?xml version="1.0"?>
<robot name="indoor_bot" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:include filename="$(find indoor_bot)/models/urdf/indoor_bot_ros2.gazebo" />

  <link name="base_footprint" />

  <joint name="base_footprint_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="base_footprint" />
    <child link="robot_footprint" />
  </joint>

  <link name="robot_footprint" />

  <joint name="robot_footprint_joint" type="fixed">
    <origin xyz="0 0 0.1" rpy="0 0 0" />
    <parent link="robot_footprint" />
    <child link="chassis" />
  </joint>

  <link name="chassis">
    <inertial>
      <mass value="5.0" />
      <origin xyz="0 0 0" rpy="0 0 0" />
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1" />
    </inertial>

    <collision name="chassis_collision">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.2" length="0.1" />
      </geometry>
    </collision>

    <visual name="chassis_visual">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.2" length="0.1" />
      </geometry>
    </visual>
  </link>

  <joint name="back_caster_joint" type="fixed">
    <parent link="chassis" />
    <child link="back_caster" />
    <origin xyz="-0.14 0 -0.05" rpy="0 0 0" />
  </joint>

  <link name="back_caster">
    <inertial>
      <mass value="0.5" />
      <origin xyz="0 0 0" rpy="0 0 0" />
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1" />
    </inertial>

    <collision name="back_caster_collision">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.05" />
      </geometry>
    </collision>

    <visual name="back_caster_visual">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.05" />
      </geometry>
    </visual>
  </link>

  <joint name="front_caster_joint" type="fixed">
    <parent link="chassis" />
    <child link="front_caster" />
    <origin xyz="0.14 0 -0.05" rpy="0 0 0" />
  </joint>

  <link name="front_caster">
    <inertial>
      <mass value="0.5" />
      <origin xyz="0 0 0" rpy="0 0 0" />
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1" />
    </inertial>

    <collision name="front_caster_collision">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.05" />
      </geometry>
    </collision>

    <visual name="front_caster_visual">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.05" />
      </geometry>
    </visual>
  </link>

  <joint name="left_wheel_hinge" type="continuous">
    <origin xyz="0 0.23 0" rpy="0 0 0" />
    <parent link="chassis" />
    <child link="left_wheel" />
    <axis xyz="0 1 0" />
    <limit effort="10000" velocity="1000" />
    <dynamics damping="0.05" friction="0.0" />
  </joint>

  <link name="left_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0" />
      <mass value="0.8" />
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1" />
    </inertial>

    <visual name="left_wheel_visual">
      <origin xyz="0 0 0" rpy="1.57079632679 0 0" />
      <geometry>
        <cylinder radius="0.1" length="0.05" />
      </geometry>
    </visual>

    <collision name="left_wheel_collision">
      <origin xyz="0 0 0" rpy="1.57079632679 0 0" />
      <geometry>
        <cylinder radius="0.1" length="0.05" />
      </geometry>
    </collision>
  </link>

  <joint name="right_wheel_hinge" type="continuous">
    <origin xyz="0 -0.23 0" rpy="0 0 0" />
    <parent link="chassis" />
    <child link="right_wheel" />
    <axis xyz="0 1 0" />
    <limit effort="10000" velocity="1000" />
    <dynamics damping="0.05" friction="0.0" />
  </joint>

  <link name="right_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0" />
      <mass value="0.8" />
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1" />
    </inertial>

    <visual name="right_wheel_visual">
      <origin xyz="0 0 0" rpy="1.57079632679 0 0" />
      <geometry>
        <cylinder radius="0.1" length="0.05" />
      </geometry>
    </visual>

    <collision name="right_wheel_collision">
      <origin xyz="0 0 0" rpy="1.57079632679 0 0" />
      <geometry>
        <cylinder radius="0.1" length="0.05" />
      </geometry>
    </collision>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="chassis" />
    <child link="camera" />
    <origin xyz="0.16 0 0.05" rpy="0 0 0" />
  </joint>

  <link name="camera">
    <inertial>
      <origin xyz="0 0 0.025" rpy="0 0 0" />
      <mass value="0.1" />
      <inertia ixx="1e-6" ixy="0.0" ixz="0.0" iyy="1e-6" iyz="0.0" izz="1e-6" />
    </inertial>

    <visual name="camera_visual">
      <origin xyz="0 0 0.025" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.05 0.05" />
      </geometry>
    </visual>

    <collision name="camera_collision">
      <origin xyz="0 0 0.025" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.05 0.05" />
      </geometry>
    </collision>
  </link>

  <joint name="hokuyo_joint" type="fixed">
    <parent link="camera" />
    <child link="hokuyo" />
    <origin xyz="0 0 0.07" rpy="0 0 0" />
  </joint>

  <link name="hokuyo">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="1e-5" />
      <inertia ixx="1e-6" ixy="0.0" ixz="0.0" iyy="1e-6" iyz="0.0" izz="1e-6" />
    </inertial>

    <visual name="hokuyo_visual">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://indoor_bot/models/hokuyo/meshes/hokuyo.dae" />
      </geometry>
    </visual>

    <collision name="hokuyo_collision">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.05 0.05" />
      </geometry>
    </collision>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="chassis" />
    <child link="imu_link" />
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>

  <link name="imu_link" />
</robot>
